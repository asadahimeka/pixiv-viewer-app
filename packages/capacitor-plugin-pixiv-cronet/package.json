{
  "name": "capacitor-plugin-pixiv-cronet",
  "version": "1.0.0",
  "description": "Pixiv Cronet plugin for direct connection via QUIC/HTTP3",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/"
  ],
  "author": "asadahimeka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/asadahimeka/pixiv-viewer-app"
  },
  "keywords": [
