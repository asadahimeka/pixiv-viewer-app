{
  "appId": "org.eu.cocomi.pxvek",
  "appName": "Pixiv Viewer",
  "webDir": "dist",
  "android": {
    "appendUserAgent": "PixivViewer/1.8",
    "buildOptions": {
      "releaseType": "APK"
    }
  },
  "ios": {
    "appendUserAgent": "PixivViewer/1.8 iPxve/1.8"
  },
  "server": {
    "//url": "http://192.168.1.45:8080",
    "//cleartext": true,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorCookies": {
      "enabled": false
    }
  }
}
